# OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Peec AI API Key
PEEC_API_KEY=your_peec_api_key_here

# Langfuse Observability (get from https://cloud.langfuse.com or self-host)
# Leave empty to disable tracing
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
# Optional: for self-hosted Langfuse (defaults to https://cloud.langfuse.com)
# LANGFUSE_HOST=https://your-langfuse-instance.com
