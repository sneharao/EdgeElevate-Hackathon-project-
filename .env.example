# EdgeElevate API Keys Configuration

# OPENROUTER: For LLM operations across different nodes
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# PEEC AI: For competitor analysis and brand visibility tracking
# Get your key from: https://app.peec.ai/api-keys (Enterprise tier required)
PEEC_API_KEY="your_peec_api_key_here"

# Q-CONTEXT (Qontext): For insight structuring and context retrieval
# Get your key from: https://app.qontext.ai
QCONTEXT_API_KEY="your_qcontext_api_key_here"

# HERA: For video generation and animation
# Get your key by contacting: support@hera.video
HERA_API_KEY="your_hera_api_key_here"

# TAVILY: For web search and review scraping (Trustpilot, G2, etc.)
# Get your key from: https://tavily.com
TAVILY_API_KEY="your_tavily_api_key_here"

# Optional: Gemini API for fallback LLM operations
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted
APP_URL="http://localhost:5173"
